{
  "name": "kws2100-kartbaserte-websystemer",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "tsc --noEmit && prettier --check .",
    "prepare": "husky",
    "build": "vite build",
    "start": "cd server && npm start",
    "db:load:server": "npm run db:postgis:install && npm run db:load:data:server && psql $DATABASE_URL < sql/prepare-data.sql",
    "db:load:data:server": "npm run db:grunnskoler:download && npm run db:grunnskoler:load:server && npm run db:kommuner:download && npm run db:kommuner:load:server && npm run db:adresser:download && npm run db:adresser:load:server",
    "db:postgis:install": "echo create extension if not exists postgis | psql $DATABASE_URL",
    "db:load": "npm run db:grunnskoler:download && npm run db:grunnskoler:load && npm run db:kommuner:download && npm run db:kommuner:load && npm run db:adresser:download && npm run db:adresser:load && npm run db:prepare:data",
    "db:prepare:data": "npm run psql:docker < sql/prepare-data.sql",
    "db:adresser:download": "download --out tmp --extract https://nedlasting.geonorge.no/geonorge/Basisdata/MatrikkelenAdresse/PostGIS/Basisdata_32_Akershus_25832_MatrikkelenAdresse_PostGIS.zip",
    "db:adresser:load": "npm run psql:docker < tmp/Basisdata_32_Akershus_25832_MatrikkelenAdresse_PostGIS.sql",
    "db:adresser:load:server": "psql $DATABASE_URL < tmp/Basisdata_32_Akershus_25832_MatrikkelenAdresse_PostGIS.sql",
    "db:grunnskoler:download": "download --out tmp --extract https://nedlasting.geonorge.no/geonorge/Befolkning/Grunnskoler/PostGIS/Befolkning_0000_Norge_25833_Grunnskoler_PostGIS.zip",
    "db:grunnskoler:load": "npm run psql:docker < tmp/Befolkning_0000_Norge_25833_Grunnskoler_PostGIS.sql",
    "db:grunnskoler:load:server": "psql $DATABASE_URL < tmp/Befolkning_0000_Norge_25833_Grunnskoler_PostGIS.sql",
    "db:kommuner:download": "download --out tmp --extract https://nedlasting.geonorge.no/geonorge/Basisdata/Kommuner/PostGIS/Basisdata_0000_Norge_25833_Kommuner_PostGIS.zip",
    "db:kommuner:load": "npm run psql:docker < tmp/Basisdata_0000_Norge_25833_Kommuner_PostGIS.sql",
    "db:kommuner:load:server": "psql $DATABASE_URL < tmp/Basisdata_0000_Norge_25833_Kommuner_PostGIS.sql",
    "psql:docker": "docker exec -i kws2100_database psql --user postgres",
    "dev": "concurrently npm:dev:client npm:dev:server",
    "dev:client": "vite",
    "dev:server": "cd server && npm run dev",
    "postinstall": "cd server && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kristiania-kws2100-2026/kws2100-kartbaserte-websystemer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kristiania-kws2100-2026/kws2100-kartbaserte-websystemer/issues"
  },
  "homepage": "https://github.com/kristiania-kws2100-2026/kws2100-kartbaserte-websystemer#readme",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "download-cli": "^1.1.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "ol": "^10.8.0",
    "proj4": "^2.20.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "type": "module"
}
