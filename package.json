{
  "name": "kws2100-kartbaserte-websystemer",
  "scripts": {
    "test": "tsc --noemit && prettier --check .",
    "dev": "concurrently npm:dev:client npm:dev:server",
    "dev:client": "vite",
    "dev:server": "cd server && npm run dev",
    "prepare": "husky",
    "db:load:docker": "npm run db:download && npm run db:load-data:docker",
    "db:load:server": "npm run db:init:server && npm run db:download && npm run db:grunnskoler:load:server && npm run db:matrikkelen:load:server",
    "db:init:server": "psql $DATABASE_URL < db/init.sql",
    "db:load-data:server": "npm run db:grunnskoler:load:server && npm run db:matrikkelen:load:server",
    "db:load-data:docker": "npm run db:stemmekretser:load:docker && npm run db:matrikkelen:load:docker && npm run db:grunnkretser:load:docker && npm run db:psql:docker < db/prepare-data.sql",
    "db:download": "npm run db:grunnskoler:download && npm run db:matrikkelen:download && npm run db:grunnkretser:download",
    "db:grunnskoler:download": "download --extract --out tmp https://nedlasting.geonorge.no/geonorge/Befolkning/Grunnskoler/PostGIS/Befolkning_0000_Norge_25833_Grunnskoler_PostGIS.zip",
    "db:grunnskoler:load:docker": "npm run db:psql:docker < tmp/Befolkning_0000_Norge_25833_Grunnskoler_PostGIS.sql",
    "db:grunnskoler:load:server": "psql $DATABASE_URL < tmp/Befolkning_0000_Norge_25833_Grunnskoler_PostGIS.sql",
    "db:matrikkelen:download": "download --extract --out tmp https://nedlasting.geonorge.no/geonorge/Basisdata/MatrikkelenAdresse/PostGIS/Basisdata_03_Oslo_25832_MatrikkelenAdresse_PostGIS.zip",
    "db:matrikkelen:load:docker": "npm run db:psql:docker < tmp/Basisdata_03_Oslo_25832_MatrikkelenAdresse_PostGIS.sql",
    "db:matrikkelen:load:server": "psql $DATABASE_URL < tmp/Basisdata_03_Oslo_25832_MatrikkelenAdresse_PostGIS.sql",
    "db:grunnkretser:download": "download --extract --out tmp https://nedlasting.geonorge.no/geonorge/Basisdata/Grunnkretser/PostGIS/Basisdata_03_Oslo_25832_Grunnkretser_PostGIS.zip",
    "db:grunnkretser:load:docker": "npm run db:psql:docker < tmp/Basisdata_03_Oslo_25832_Grunnkretser_PostGIS.sql",
    "db:grunnkretser:load:server": "psql $DATABASE_URL < tmp/Basisdata_03_Oslo_25832_Grunnkretser_PostGIS.sql",
    "db:stemmekretser:download": "download --extract --out tmp https://nedlasting.geonorge.no/geonorge/Basisdata/StemmekretserMed2024Inndeling/PostGIS/Basisdata_0000_Norge_25835_StemmekretserMed2024Inndeling_PostGIS.zip",
    "db:stemmekretser:load:docker": "npm run db:psql:docker < tmp/Basisdata_0000_Norge_25835_StemmekretserMed2024Inndeling_PostGIS.sql",
    "db:stemmekretser:load:server": "psql $DATABASE_URL < tmp/Basisdata_0000_Norge_25835_StemmekretserMed2024Inndeling_PostGIS.sql",
    "db:psql:docker": "docker exec -i kws2100 /usr/bin/psql --user postgres",
    "start": "cd server && npm start",
    "build": "vite build",
    "postinstall": "cd server && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kristiania-kws2100-2026/kws2100-kartbaserte-websystemer.git"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "download-cli": "^1.1.1",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "husky": "^9.1.7",
    "ol": "^10.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "type": "module"
}
