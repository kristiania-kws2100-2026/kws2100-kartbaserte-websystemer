{
  "name": "kws2100-kartbaserte-websystemer-practice",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "cd server && npm start",
    "dev": "concurrently npm:dev:client npm:dev:server",
    "dev:client": "vite",
    "dev:server": "cd server && npm run dev",
    "build": "vite build",
    "test": "tsc --noEmit && prettier --check .",
    "server:db:load": "psql $DATABASE_URL < sql/initialize.sql && npm run db:download && psql $DATABASE_URL < tmp/*.sql && psql $DATABASE_URL < sql/prepare-data.sql",
    "db:load": "npm run docker:psql < sql/initialize.sql && npm run db:load:data && npm run docker:psql < sql/prepare-data.sql",
    "db:load:data": "npm run db:download && npm run db:import",
    "db:download": "npm run db:download:matrikkelen && npm run db:download:grunnkretser",
    "db:download:matrikkelen": "download -o tmp --extract https://nedlasting.geonorge.no/geonorge/Basisdata/MatrikkelenAdresse/PostGIS/Basisdata_03_Oslo_25832_MatrikkelenAdresse_PostGIS.zip",
    "db:download:grunnkretser": "download -o tmp --extract https://nedlasting.geonorge.no/geonorge/Basisdata/Grunnkretser/PostGIS/Basisdata_03_Oslo_25832_Grunnkretser_PostGIS.zip",
    "db:import": "npm run docker:psql < tmp/Basisdata_03_Oslo_25832_Grunnkretser_PostGIS.sql && npm run docker:psql < tmp/Basisdata_03_Oslo_25832_MatrikkelenAdresse_PostGIS.sql",
    "docker:psql": "docker exec -i lecture10 psql --user postgres",
    "prepare": "husky",
    "postinstall": "cd server && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kristiania-kws2100-2026/kws2100-kartbaserte-websystemer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kristiania-kws2100-2026/kws2100-kartbaserte-websystemer/issues"
  },
  "homepage": "https://github.com/kristiania-kws2100-2026/kws2100-kartbaserte-websystemer#readme",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "download-cli": "^1.1.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "ol": "^10.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
