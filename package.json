{
  "name": "kws2100-kartbaserte-websystemer",
  "scripts": {
    "test": "tsc --noemit && prettier --check .",
    "dev": "vite",
    "prepare": "husky",
    "db:load:docker": "npm run db:grunnskoler:download && npm run db:grunnskoler:load:docker",
    "db:grunnskoler:download": "download --extract --out tmp https://nedlasting.geonorge.no/geonorge/Befolkning/Grunnskoler/PostGIS/Befolkning_0000_Norge_25833_Grunnskoler_PostGIS.zip",
    "db:grunnskoler:load:docker": "npm run db:pg:docker < tmp/Befolkning_0000_Norge_25833_Grunnskoler_PostGIS.sql",
    "db:pg:docker": "docker exec -i kws2100 /usr/bin/psql --user postgres",
    "start": "cd server && npm start",
    "build": "vite build",
    "postinstall": "cd server && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kristiania-kws2100-2026/kws2100-kartbaserte-websystemer.git"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "download-cli": "^1.1.1",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "husky": "^9.1.7",
    "ol": "^10.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "type": "module"
}
