  "scripts": {
    "dev": "npm run dev:server",
    "dev:server": "cd server && npm run dev",
    "test": "tsc --noEmit && prettier --check .",
    "db:load": "npm run db:grunnkretser:download && npm run db:grunnkretser:import && npm run db:prepare-data",
    "db:grunnkretser:download": "download -o tmp --extract https://nedlasting.geonorge.no/geonorge/Basisdata/Grunnkretser/PostGIS/Basisdata_03_Oslo_25832_Grunnkretser_PostGIS.zip",
    "db:grunnkretser:import": "npm run docker:psql < tmp/Basisdata_03_Oslo_25832_Grunnkretser_PostGIS.sql",
    "db:prepare-data": "npm run docker:psql < sql/prepare-data.sql",
    "docker:psql": "docker exec -i lecture10 psql --user postgres",
    "prepare": "husky"
  },
